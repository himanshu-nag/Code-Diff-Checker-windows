<Window x:Class="DiffTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DiffTool"
        mc:Ignorable="d"
        Title="Diff Checker" Height="750" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#ffffff">
    <Window.Resources>
        <Style x:Key="ProButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="#0066cc"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#0066cc"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="0" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#004499"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <DockPanel>
        <!-- Top Header -->
        <Border DockPanel.Dock="Top" Background="#f5f5f5" BorderBrush="#e0e0e0" BorderThickness="0,0,0,1">
            <Grid Margin="15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Diff Checker" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" Foreground="#222222"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#ffcccc" BorderBrush="#ff9999" BorderThickness="1" CornerRadius="4" Padding="8,4" Margin="0,0,8,0">
                        <TextBlock x:Name="lblRemovals" Text="−  0 removals" Foreground="#cc0000" FontWeight="Bold" FontSize="12"/>
                    </Border>
                    <TextBlock Text="14 lines" Foreground="#666666" VerticalAlignment="Center" Margin="8,0"/>
                    <Button Content="Copy" Style="{StaticResource ProButtonStyle}" Padding="8,4" Margin="8,0" Click="MenuCopyDiff_Click"/>
                    <TextBlock Text="→" Foreground="#999999" VerticalAlignment="Center" Margin="8,0" FontSize="14" FontWeight="Bold"/>
                    <Border Background="#ccffcc" BorderBrush="#99ff99" BorderThickness="1" CornerRadius="4" Padding="8,4" Margin="8,0,0,0">
                        <TextBlock x:Name="lblAdditions" Text="+  0 additions" Foreground="#009900" FontWeight="Bold" FontSize="12"/>
                    </Border>
                    <TextBlock Text="14 lines" Foreground="#666666" VerticalAlignment="Center" Margin="8,0"/>
                    <Button Content="Copy" Style="{StaticResource ProButtonStyle}" Padding="8,4" Margin="8,0" Click="MenuCopyDiff_Click"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Bottom Status Bar -->
        <StatusBar DockPanel.Dock="Bottom" Background="#f5f5f5" BorderBrush="#e0e0e0" BorderThickness="0,1,0,0">
            <StatusBarItem HorizontalAlignment="Left">
                <TextBlock x:Name="statusText" Text="Ready" Foreground="#666666"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <Button Content="Clear All" Click="MenuClear_Click" Style="{StaticResource ProButtonStyle}" Padding="10,5" Margin="3"/>
                    <Button Content="Export to PDF" Click="btnExportPDF_Click" Style="{StaticResource ProButtonStyle}" Padding="10,5" Margin="3"/>
                    <Button Content="Save as file" Click="MenuSaveDiff_Click" Style="{StaticResource ProButtonStyle}" Padding="10,5" Margin="3"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
        
        <!-- Main Content -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Left Sidebar -->
            <Border Grid.Column="0" BorderBrush="#e0e0e0" BorderThickness="0,0,1,0" Background="#fafafa">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Tabs -->
                    <TabControl Grid.Row="0" Background="White" BorderBrush="#e0e0e0" BorderThickness="0,0,0,1">
                        <TabItem Header="Tools">
                            <StackPanel Background="White">
                                <TextBlock Text="Compare" FontWeight="Bold" FontSize="12" Foreground="#333333" Margin="12,8,8,8"/>
                                <RadioButton x:Name="rbFiles" Content="Files" IsChecked="True" Margin="8,0,0,8" Checked="rbFiles_Checked" Foreground="#555555"/>
                                <RadioButton x:Name="rbFolders" Content="Folders" Margin="8,0,0,0" Checked="rbFolders_Checked" Foreground="#555555"/>
                            </StackPanel>
                        </TabItem>
                        <TabItem Header="History">
                            <TextBlock Text="No history" Foreground="#999999" Margin="12"/>
                        </TabItem>
                    </TabControl>
                    
                    <!-- Tools Options -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Background="White">
                            <!-- File Selection -->
                            <TextBlock Text="ORIGINAL" FontSize="10" FontWeight="Bold" Foreground="#666666" Margin="12,12,8,4"/>
                            <Button x:Name="btnSelect1" Content="Select File or Folder" Click="btnSelect1_Click" Style="{StaticResource ProButtonStyle}" Margin="8,0,8,4"/>
                            <TextBox x:Name="txtPath1" Margin="8,0,8,12" Padding="6"/>
                            
                            <TextBlock Text="CHANGED" FontSize="10" FontWeight="Bold" Foreground="#666666" Margin="12,0,8,4"/>
                            <Button x:Name="btnSelect2" Content="Select File or Folder" Click="btnSelect2_Click" Style="{StaticResource ProButtonStyle}" Margin="8,0,8,4"/>
                            <TextBox x:Name="txtPath2" Margin="8,0,8,12" Padding="6"/>
                            
                            <!-- Options -->
                            <TextBlock Text="OPTIONS" FontSize="10" FontWeight="Bold" Foreground="#666666" Margin="12,0,8,8"/>
                            <CheckBox x:Name="chkRealTime" Content="Real-time diff" Margin="12,0,0,6" Checked="chkRealTime_Checked" Unchecked="chkRealTime_Checked" Foreground="#555555"/>
                            <CheckBox x:Name="chkUnifiedDiff" Content="Unified diff" Margin="12,0,0,6" Checked="chkUnifiedDiff_Checked" Unchecked="chkUnifiedDiff_Checked" Foreground="#555555"/>
                            <CheckBox x:Name="chkCollapse" Content="Collapse identical" Margin="12,0,0,12" Foreground="#555555"/>
                            
                            <!-- Highlight -->
                            <TextBlock Text="HIGHLIGHT" FontSize="10" FontWeight="Bold" Foreground="#666666" Margin="12,0,8,8"/>
                            <RadioButton x:Name="rbHighlightWord" Content="Word" IsChecked="True" GroupName="Highlight" Margin="12,0,0,6" Foreground="#555555"/>
                            <RadioButton x:Name="rbHighlightCharacter" Content="Character" GroupName="Highlight" Margin="12,0,0,12" Foreground="#555555"/>
                            
                            <!-- Syntax -->
                            <TextBlock Text="SYNTAX" FontSize="10" FontWeight="Bold" Foreground="#666666" Margin="12,0,8,4"/>
                            <ComboBox x:Name="cbSyntax" SelectedIndex="0" Margin="8,0,8,12">
                                <ComboBoxItem>Auto-detect</ComboBoxItem>
                                <ComboBoxItem>C#</ComboBoxItem>
                                <ComboBoxItem>JavaScript</ComboBoxItem>
                                <ComboBoxItem>HTML</ComboBoxItem>
                                <ComboBoxItem>JSON</ComboBoxItem>
                                <ComboBoxItem>Python</ComboBoxItem>
                            </ComboBox>
                            
                            <!-- Tools -->
                            <TextBlock Text="TOOLS" FontSize="10" FontWeight="Bold" Foreground="#666666" Margin="12,0,8,8"/>
                            <Button Content="Lowercase" Style="{StaticResource ProButtonStyle}" Margin="8,0,8,4" FontSize="11" Click="btnLowercase_Click"/>
                            <Button Content="Sort lines" Style="{StaticResource ProButtonStyle}" Margin="8,0,8,4" FontSize="11" Click="btnSortLines_Click"/>
                            <Button Content="Trim whitespace" Style="{StaticResource ProButtonStyle}" Margin="8,0,8,12" FontSize="11" Click="btnTrimWhitespace_Click"/>
                        </StackPanel>
                    </ScrollViewer>
                    
                    <!-- Compare Button -->
                    <Border Grid.Row="2" BorderBrush="#e0e0e0" BorderThickness="0,1,0,0" Background="White" Padding="8">
                        <Button x:Name="btnCompare" Content="Compare" Click="btnCompare_Click" Style="{StaticResource ProButtonStyle}" FontWeight="Bold" Padding="12,10" FontSize="13"/>
                    </Border>
                </Grid>
            </Border>
            
            <!-- Main Display Area -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Statistics Panel -->
                <Border Grid.Row="0" Background="White" BorderBrush="#e0e0e0" BorderThickness="0,0,0,1" Padding="15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="lblFileInfo" Text="Ready to compare" Foreground="#666666" FontSize="11"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="20,0,0,0">
                            <TextBlock Text="Changed lines:" Foreground="#999999" FontSize="10" Margin="0,0,8,0"/>
                            <TextBlock x:Name="lblChangeStats" Text="0" Foreground="#0066cc" FontWeight="Bold" FontSize="10"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="20,0,0,0">
                            <TextBlock Text="Additions:" Foreground="#999999" FontSize="10" Margin="0,0,8,0"/>
                            <TextBlock x:Name="lblAddStats" Text="0" Foreground="#00aa00" FontWeight="Bold" FontSize="10"/>
                        </StackPanel>
                        <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="20,0,0,0">
                            <TextBlock Text="Deletions:" Foreground="#999999" FontSize="10" Margin="0,0,8,0"/>
                            <TextBlock x:Name="lblDelStats" Text="0" Foreground="#cc0000" FontWeight="Bold" FontSize="10"/>
                        </StackPanel>
                        <TextBlock Grid.Column="4" x:Name="lblSimilarity" Text="100% match" Foreground="#999999" FontSize="10" Margin="20,0,0,0"/>
                    </Grid>
                </Border>
                
                <!-- Code Panels Grid -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Left Code Panel with Line Numbers -->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Background="#f5f5f5" BorderBrush="#e0e0e0" BorderThickness="0,0,0,1" Padding="12,8">
                            <StackPanel>
                                <TextBlock Text="Original" FontWeight="Bold" FontSize="13" Foreground="#333333"/>
                                <TextBlock x:Name="lblLeftFileInfo" Text="" Foreground="#999999" FontSize="9" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <!-- Line Numbers -->
                            <Border Grid.Column="0" Background="#fafafa" BorderBrush="#e0e0e0" BorderThickness="0,0,1,0" Padding="8,0">
                                <RichTextBox x:Name="rtbLeftLineNumbers" IsReadOnly="True" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Hidden" FontFamily="Consolas" FontSize="12" Background="#fafafa" Foreground="#999999" BorderThickness="0" Padding="0,12,8,12"/>
                            </Border>
                            <!-- Code -->
                            <RichTextBox Grid.Column="1" x:Name="rtbLeft" IsReadOnly="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="12" Background="White" Padding="12" BorderThickness="0"/>
                        </Grid>
                    </Grid>
                    
                    <!-- Splitter -->
                    <GridSplitter Grid.Column="1" Width="1" HorizontalAlignment="Stretch" Background="#e0e0e0"/>
                    
                    <!-- Right Code Panel with Line Numbers -->
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Background="#f5f5f5" BorderBrush="#e0e0e0" BorderThickness="0,0,0,1" Padding="12,8">
                            <StackPanel>
                                <TextBlock Text="Changed" FontWeight="Bold" FontSize="13" Foreground="#333333"/>
                                <TextBlock x:Name="lblRightFileInfo" Text="" Foreground="#999999" FontSize="9" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <!-- Line Numbers -->
                            <Border Grid.Column="0" Background="#fafafa" BorderBrush="#e0e0e0" BorderThickness="0,0,1,0" Padding="8,0">
                                <RichTextBox x:Name="rtbRightLineNumbers" IsReadOnly="True" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Hidden" FontFamily="Consolas" FontSize="12" Background="#fafafa" Foreground="#999999" BorderThickness="0" Padding="0,12,8,12"/>
                            </Border>
                            <!-- Code -->
                            <RichTextBox Grid.Column="1" x:Name="rtbRight" IsReadOnly="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="12" Background="White" Padding="12" BorderThickness="0"/>
                        </Grid>
                    </Grid>
                    
                    <!-- Unified view hidden by default -->
                    <RichTextBox x:Name="rtbUnified" Grid.Column="0" Grid.ColumnSpan="3" Visibility="Collapsed" IsReadOnly="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="12" Background="White" Padding="12" BorderThickness="0"/>
                </Grid>
            </Grid>
        </Grid>
    </DockPanel>
</Window>